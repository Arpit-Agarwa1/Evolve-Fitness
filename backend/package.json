{
  "name": "evolve-fitness-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Evolve Fitness REST API — MVC + MongoDB",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "admin:create": "node scripts/createAdmin.js",
    "db:list": "node scripts/listMongoCollections.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5"
  }
}

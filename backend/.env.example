# Default 5001 — macOS often reserves 5000 (AirPlay)
PORT=5001

# Database name (no spaces — MongoDB rejects spaces in database names).
MONGODB_DB_NAME=evolve_fitness_data

# Local MongoDB (path includes DB name):
# MONGODB_URI=mongodb://127.0.0.1:27017/evolve_fitness_data

# Atlas — include /evolve_fitness_data before ?, or paste ...net/?... and MONGODB_DB_NAME will be inserted:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/evolve_fitness_data?retryWrites=true&w=majority

MONGODB_URI=mongodb://127.0.0.1:27017/evolve_fitness_data

# CORS — required for browser calls from your Vercel app to this Render API.
# Use your real Vercel URL(s), comma-separated, no trailing slashes:
# CORS_ORIGIN=https://your-app.vercel.app,https://your-app-git-main-xxx.vercel.app
#
# Local Vite only:
# CORS_ORIGIN=http://localhost:5173

# —— Owner admin (POST /api/admin/login) ——
# Required: JWT signing secret (sessions are not stored in MongoDB).
# Prefer hex only (no $, #, !) — some hosts mangle those in env vars.
# ADMIN_JWT_SECRET=long-random-hex-string   # openssl rand -hex 32
# ADMIN_JWT_EXPIRES=12h                     # optional
#
# Login credentials: store in MongoDB collection `admins` (email + passwordHash bcrypt).
# Easiest: npm run admin:create -- owner@yourgym.com "YourPassword"
# Optional legacy fallback (env-only admin, no MongoDB row):
# ADMIN_EMAIL=owner@yourgym.com
# ADMIN_PASSWORD_BCRYPT=$2a$10$...

# —— WhatsApp Cloud API (optional) — thank-you template to member after registration ——
# Create a template in Meta Business Manager (e.g. body: "Hi {{1}}, thank you for registering with Evolve Fitness!").
# WHATSAPP_CLOUD_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_REGISTRATION_TEMPLATE_NAME=evolve_registration_thanks
# WHATSAPP_REGISTRATION_TEMPLATE_LANG=en
# WHATSAPP_REGISTRATION_TEMPLATE_BODY_PARAMS=1
# WHATSAPP_GRAPH_API_VERSION=v21.0

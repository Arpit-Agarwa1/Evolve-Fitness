# Default 5001 — macOS often reserves 5000 (AirPlay)
PORT=5001

# Database name (no spaces — MongoDB rejects spaces in database names).
MONGODB_DB_NAME=evolve_fitness_data

# Local MongoDB (path includes DB name):
# MONGODB_URI=mongodb://127.0.0.1:27017/evolve_fitness_data

# Atlas — include /evolve_fitness_data before ?, or paste ...net/?... and MONGODB_DB_NAME will be inserted:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/evolve_fitness_data?retryWrites=true&w=majority

MONGODB_URI=mongodb://127.0.0.1:27017/evolve_fitness_data

# CORS — browser calls from your frontend (custom domain, Vercel, admin hitting Render directly).
# Production: list every origin that should call this API (comma-separated). www ↔ apex is auto-added.
# Example:
# CORS_ORIGIN=https://evolvestudio.fitness,https://your-app.vercel.app
#
# In production, when CORS_ORIGIN is set, the app also merges PUBLIC_SITE_ORIGIN (default https://evolvestudio.fitness)
# so the live site always works even if you forget to add it to CORS_ORIGIN. Override:
# PUBLIC_SITE_ORIGIN=https://your-custom-domain.com
#
# If unset: all origins allowed (OK for local dev; in production a warning is logged — set CORS_ORIGIN on Render).
# Local Vite (5173) + preview (4173) are auto-merged when NODE_ENV is not production.
#
# Optional: allow any https://*.vercel.app (preview deploys): CORS_ALLOW_VERCEL_PREVIEWS=1
# Optional: log blocked origins in production: CORS_LOG_BLOCKED=1
# Optional: do not merge default public site (forks): CORS_SKIP_DEFAULT_SITE=1

# —— Owner admin (POST /api/admin/login) ——
# Required: JWT signing secret (sessions are not stored in MongoDB).
# Prefer hex only (no $, #, !) — some hosts mangle those in env vars.
# ADMIN_JWT_SECRET=long-random-hex-string   # openssl rand -hex 32
# ADMIN_JWT_EXPIRES=12h                     # optional
#
# Login credentials: store in MongoDB collection `admins` (email + passwordHash bcrypt).
# Easiest: npm run admin:create -- owner@yourgym.com "YourPassword"
# Optional legacy fallback (env-only admin, no MongoDB row):
# ADMIN_EMAIL=owner@yourgym.com
# ADMIN_PASSWORD_BCRYPT=$2a$10$...

# —— WhatsApp Cloud API (optional) — thank-you template to member after registration ——
# Create a template in Meta Business Manager (e.g. body: "Hi {{1}}, thank you for registering with Evolve Fitness!").
# WHATSAPP_CLOUD_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_REGISTRATION_TEMPLATE_NAME=evolve_registration_thanks
# WHATSAPP_REGISTRATION_TEMPLATE_LANG=en
# WHATSAPP_REGISTRATION_TEMPLATE_BODY_PARAMS=1
# WHATSAPP_GRAPH_API_VERSION=v21.0

# —— Trainer photos (optional, recommended on Render) ——
# Without this, images are saved on the API disk (often wiped on redeploy).
# Cloudinary: Dashboard → Settings → copy API Environment variable as CLOUDINARY_URL
# (format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME)
# CLOUDINARY_URL=cloudinary://key:secret@your_cloud_name
# Optional folder prefix for uploads (default evolve-fitness/trainers):
# CLOUDINARY_TRAINER_FOLDER=evolve-fitness/trainers
#
# Or set three vars instead of CLOUDINARY_URL:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

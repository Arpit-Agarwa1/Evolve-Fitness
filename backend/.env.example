# Default 5001 — macOS often reserves 5000 (AirPlay)
PORT=5001

# Database name (no spaces — MongoDB rejects spaces in database names).
MONGODB_DB_NAME=evolve_fitness_data

# Local MongoDB (path includes DB name):
# MONGODB_URI=mongodb://127.0.0.1:27017/evolve_fitness_data

# Atlas — include /evolve_fitness_data before ?, or paste ...net/?... and MONGODB_DB_NAME will be inserted:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/evolve_fitness_data?retryWrites=true&w=majority

MONGODB_URI=mongodb://127.0.0.1:27017/evolve_fitness_data

# CORS — required for browser calls from your Vercel app to this Render API.
# Use your real Vercel URL(s), comma-separated, no trailing slashes:
# CORS_ORIGIN=https://your-app.vercel.app,https://your-app-git-main-xxx.vercel.app
#
# Local Vite only:
# CORS_ORIGIN=http://localhost:5173

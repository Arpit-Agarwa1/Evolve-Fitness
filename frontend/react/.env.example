# Production: public URL of your API — no trailing slash.
# This repo commits `.env.production` pointing at Render; override in Vercel → Environment if needed.
# https://evolve-fitness-backend.onrender.com
#
# Leave unset for local dev; Vite proxies /api to the backend (see vite.config.js).
VITE_API_URL=

# WhatsApp click-to-chat after contact/register (digits only, country code, no +). Default: 919876543210
# VITE_WHATSAPP_NUMBER=919876543210

# Public site URL for canonical tags, OG URLs, and sitemap (no trailing slash).
# If unset in the browser, the current origin is used (good for *.vercel.app). Set when you want one fixed canonical host.
# VITE_SITE_URL=https://your-custom-domain.com

# Optional: absolute URL to a 1200×630 image for Open Graph / Twitter previews.
# VITE_OG_IMAGE_URL=https://your-custom-domain.com/og-image.jpg

# Optional: force direct API host (skips Vercel /api proxy — you must set CORS on Render).
# Leave empty for production on Vercel: `vercel.json` rewrites /api → Render (same origin, no CORS).
# Local dev: leave unset; Vite proxies /api (vite.config.js).
# VITE_API_URL=https://evolve-fitness-backend.onrender.com
VITE_API_URL=

# WhatsApp click-to-chat after contact/register (digits only, country code, no +). Default: 919024301606
# VITE_WHATSAPP_NUMBER=919024301606

# Google Maps (Contact page) — pick one:
# A) Paste full iframe src from Google Maps → Share → Embed a map (no API billing).
# VITE_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...
# B) Maps Embed API key (Embed API enabled in Google Cloud; embed usage is typically free tier).
# VITE_GOOGLE_MAPS_API_KEY=

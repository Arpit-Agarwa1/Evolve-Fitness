# Used automatically by `vite build` (Vercel production builds).
# Canonical site URL for SEO (no trailing slash). Override in Vercel → Environment if the host changes.
VITE_SITE_URL=https://evolvestudio.fitness

# Do NOT set VITE_API_URL here — production uses same-origin `/api` and vercel.json proxies to Render (avoids CORS).
# Only set VITE_API_URL in Vercel if you intentionally call the API host directly (then configure CORS on Render).

# Optional: WhatsApp for post–contact/register prompts (digits only). Default in code: 919024301606
# VITE_WHATSAPP_NUMBER=919024301606
